# Copy to .env (chmod 600) before starting the service.
# All values are optional — the backend boots without them, but features degrade.

# Anthropic API key for live AI incident analysis. Unset → rule-based fallback.
ANTHROPIC_API_KEY=

# Override the Anthropic model used by /api/analyze. Default = claude-sonnet-4-6.
# BV_ANALYZE_MODEL=claude-opus-4-7

# Comma-separated CORS allowlist. Only matters when the frontend is served from
# a different origin than the API. Same-origin prod deployments can leave this
# at the default (localhost only) — it is unused at runtime.
# BV_CORS_ORIGINS=https://dashboard.example.com

# Shared-secret HMAC tokens. When set, /api/analyze requires X-Analyze-Token
# and /api/vlm/reload requires X-Reload-Token. Strongly recommended on any
# host reachable from outside localhost.
BV_ANALYZE_TOKEN=
BV_RELOAD_TOKEN=

# Per-IP rate limits (slowapi syntax). Defaults shown.
# BV_ANALYZE_RATE=20/minute
# BV_RELOAD_RATE=5/minute

# Listener config consumed by deploy/run-prod.sh.
# BV_PORT=8000
# Worker count. Keep at 1: VLM data is per-process and /api/vlm/reload would
# otherwise desync across workers. Bumping requires an external cache.
# BV_WORKERS=1
